# ============================================================
# Career Coaching Survey — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values
# Never commit .env to git — it contains secrets
# ============================================================

# ---- Google Service Account --------------------------------
# Path to your Google service account credentials JSON file
# See README for how to create this
GOOGLE_SERVICE_ACCOUNT_JSON=secrets/service_account.json

# ---- Google Form -------------------------------------------
# The main survey Google Form ID
# Found in the form URL:
# https://docs.google.com/forms/d/e/FORM_ID/viewform
#                                        ↑ this part
GOOGLE_FORM_ID=1a541_J6tBfLOoQB-ZdNH8I1UBlYw1qQ4MS6dPJvsb3c

# ---- Google Sheets -----------------------------------------
# The spreadsheet ID containing Form Responses 2 and Scores tabs
# Found in the sheet URL:
# https://docs.google.com/spreadsheets/d/SHEET_ID/edit
#                                              ↑ this part
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Sheet tab names (change only if you renamed them)
RESPONSE_SHEET_NAME=Form Responses 2
SCORES_SHEET_NAME=Scores

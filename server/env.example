# ============================================================
# Career Coaching Server — Environment Variables
# ============================================================

# Shared secret between Apps Script and this server
# Apps Script sends this in X-Webhook-Secret header
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=your_secret_here

# Path to survey JSON (default: ../src/survey_versions/survey_v2.json)
# Override if deploying server separately from the repo
# SURVEY_JSON_PATH=/path/to/survey_v2.json
